---
import AnimaSymbolSpinning from "./AnimaSymbolSpinning.tsx";
import ChatInput from "./ChatInput.tsx";
import ThemeToggle from "./ThemeToggle.tsx";
---

<section class="h-screen min-h-screen flex flex-col px-6 relative overflow-hidden">
  <!-- Symbol + title pinned to center-top area -->
  <div class="flex-1 flex flex-col items-center justify-center min-h-0">
    <div class="mb-6">
      <AnimaSymbolSpinning client:load />
    </div>

    <!-- <h1 class="font-serif italic text-xl sm:text-2xl md:text-3xl text-foreground leading-tight text-center mb-2">
      A mind that remains. A soul that remembers.
    </h1>

    <p class="font-mono text-[9px] tracking-[0.3em] uppercase text-muted-foreground/40">
      the first AI companion with an open mind
    </p> -->
  </div>

  <!-- Theme toggle — top right -->
  <div class="absolute top-6 right-6 z-10">
    <ThemeToggle client:load />
  </div>

  <!-- Chat pinned to bottom -->
  <div class="shrink-0 w-full max-w-2xl mx-auto pb-12">
    <ChatInput client:load />
    <div class="flex justify-center mt-3">
      <span class="font-mono text-[9px] tracking-[0.2em] uppercase text-muted-foreground/30">
     
        offline — comeback soon
      </span>
    </div>
  </div>
</section>
