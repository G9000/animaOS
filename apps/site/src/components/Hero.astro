---
import AnimaSymbolSpinning from "./AnimaSymbolSpinning.tsx";
import WaitlistForm from "./WaitlistForm.tsx";
---

<section class="min-h-screen flex flex-col items-center justify-center px-6 text-center relative overflow-hidden">
  <!-- Symbol takes center stage -->
  <div class="mb-8">
    <AnimaSymbolSpinning client:load />
  </div>

  <h1 class="font-serif italic text-2xl sm:text-3xl md:text-4xl text-text leading-tight">
    A mind that remains.<br />A soul that remembers.
  </h1>

  <p class="mt-4 font-mono text-[10px] tracking-[0.2em] uppercase text-text-muted">
    Local-first &middot; Encrypted &middot; Sovereign
  </p>

  <div class="mt-10 w-full">
    <WaitlistForm client:load />
  </div>
</section>
