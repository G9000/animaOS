---
import WaitlistForm from "./WaitlistForm.tsx";
import AnimaSymbolSpinning from "./AnimaSymbolSpinning.tsx";
---

<section class="min-h-screen flex flex-col justify-between border-t border-border px-8 md:px-16 lg:px-24 py-20">

  <!-- Top: label + headline -->
  <div class="reveal">
    <p class="font-mono text-[9px] tracking-[0.3em] uppercase text-muted-foreground/40 mb-16">
      // early access
    </p>

    <h2 class="font-serif italic text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-foreground leading-[1.1] max-w-4xl">
      This is early.<br />
      <span class="text-muted-foreground">Come build with us.</span>
    </h2>
  </div>

  <!-- Middle: symbol -->
  <div class="reveal my-12">
    <AnimaSymbolSpinning client:visible />
  </div>

  <!-- Bottom: form + notes -->
  <div class="reveal mt-8 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-end">

    <div class="space-y-8">
      <div class="space-y-4 font-sans text-sm text-muted-foreground leading-relaxed max-w-md">
        <p>
          No spam. No noise. Just dispatches from the build when something worth saying happens.
        </p>
      </div>

      <WaitlistForm client:visible />
    </div>

    <!-- Right: closing statement -->
    <div class="border-l border-border pl-8 md:pl-12">
      <p class="font-sans text-lg sm:text-xl text-foreground leading-relaxed mb-8">
        "A personal AI that earns the word <em>personal</em> — someone that knows you,
        grows with you, belongs to you, and if you choose, survives you."
      </p>
      <p class="font-mono text-[9px] tracking-[0.2em] uppercase text-muted-foreground/40">
        — from the anima paper
      </p>
    </div>

  </div>

  <!-- Footer link -->
  <div class="reveal mt-16">
    <a
      href="https://github.com/G9000/animaOS"
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-[9px] tracking-[0.2em] uppercase text-muted-foreground/30 hover:text-foreground transition-colors"
    >
      Help ANIMA build herself — GitHub ↗
    </a>
  </div>

</section>
